#include <iostream>
#include <string>

size_t rfind_first_not_of(std::string str, std::string del) {
    reverse(str.begin(), str.end());
    return str.find_first_not_of(del);
}

size_t num_of_w(std::string s, std::string del) {
    size_t size = 0;

    s.erase(s.size() - rfind_first_not_of(s, del), rfind_first_not_of(s, del));
    while (!s.empty()) {
        s.erase(0, s.find_first_not_of(del));
        ++size;
        s.erase(0, s.find_first_of(del));
    }
    return size;
}
std::string word_of(std::string& s, std::string del) {
    std::string word;
    if (!s.empty()) {
        s.erase(0, s.find_first_not_of(del));
        word = s.substr(0, s.find_first_of(del));
        s.erase(0, s.find_first_of(del));
    }
    return word;
}
void words_of_to(std::string s, std::string* words, std::string del, size_t size) {
    for (size_t i = 0; i < size; ++i) {
        words[i] = word_of(s, del);
    }
}

template <class T>
void swap(T& s1, T& s2) {
    T temp = s1;
    s1 = s2;
    s2 = temp;
}
void len_bubbleSort(std::string* arr, size_t size) {
    for (bool transposition{ true }; transposition && size > 1; --size) {
        transposition = false;
        for (size_t i{ 1 }; i < size; ++i) {
            if (arr[i].size() > arr[i - 1].size()) {
                swap(arr[i], arr[i - 1]);
                transposition = true;
            }
        }
    }
}
void lex_bubbleSort(std::string* arr, std::string* arr_notol, size_t size) {
    for (bool transposition{ true }; transposition && size > 1; --size) {
        transposition = false;
        for (size_t i{ 1 }; i < size; ++i) {
            if (arr[i] < arr[i - 1]) {
                swap(arr[i], arr[i - 1]);
                swap(arr_notol[i], arr_notol[i - 1]);
                transposition = true;
            }
        }
    }
}

bool polindrom(std::string s) {
    if (s.size() == 1) return false;
    if (!s.empty()) {
        for (size_t i = 0, j = s.size() - 1; i < j; ++i, --j) {
            if (s[i] != s[j]) return false;
        }
        return true;
    }
    return false;
}
void words_to_polindroms(std::string* words, std::string* polindroms, size_t size_w, size_t& size_p) {
    for (size_t i = 0; i < size_w; ++i) {
        if (polindrom(words[i])) {
            polindroms[size_p] = words[i];
            ++size_p;
        }
    }
}

void rewrite(std::string* polindroms1, std::string* polindroms, size_t size_p) {
    for (size_t i = 0; i < size_p; ++i) {
        polindroms[i] = polindroms1[i];
    }
}
void tolover(std::string s) {
    size_t w_size = s.size();
    for (size_t j = 0; j < w_size; ++j) {
        if (s[j] < 90) s[j] = s[j] + 32;
    }
}
void tolover_arr(std::string* words, size_t size_w) {
    for (size_t i = 0; i < size_w; ++i) {
        tolover(words[i]);
    }
}

bool chek(std::string* polindroms_k, std::string word, size_t k) {
    for (size_t i = 0; i < k; ++i) {
        if (polindroms_k[i] == word) return true;
    }
    return false;
}
void replace(std::string& s, std::string* polindroms_notol, std::string del, size_t size_w, size_t k) {
    std::string word;
    size_t pos = 0, j = 0;
    for (size_t i = 0; i < size_w && j < k; ++i) {

        pos = s.find_first_not_of(del, pos);
        word = s.substr(pos, s.find_first_of(del, pos) - pos);

        if (chek(polindroms_notol, word, k)) {
            s.erase(pos, s.find_first_of(del, pos) - pos);
            s.insert(pos, polindroms_notol[j]);
            ++j;
        }
        pos = s.find_first_of(del, pos);
    }
}

int main() {
    const size_t k = 3;
    std::string s = "The tactical radar detected a fast racecar while the civic leader used a kayak to cross the river.";
    std::string del = " ,.";

    size_t size_p = 0;
    size_t size_w = num_of_w(s, del);   //число слов

    std::string* words = new std::string[size_w];
    std::string* polindroms1 = new std::string[size_w];
    std::string* polindroms_notol = new std::string[k];
    std::string* polindroms_k = new std::string[k];

    words_of_to(s, words, del, size_w);     //заполнили словами words
    words_to_polindroms(words, polindroms1, size_w, size_p);    //заполнили пaлиндромами
    std::string* polindroms = new std::string[size_p];

    rewrite(polindroms1, polindroms, size_p);
    len_bubbleSort(polindroms, size_p);
    rewrite(polindroms, polindroms_k, k);
    rewrite(polindroms_k, polindroms_notol, k);
    tolover_arr(polindroms_k, k);    //привести к ниж регистру
    lex_bubbleSort(polindroms_k, polindroms_notol, k);    //отсортировали 'к' пaлиндромов по лексике

    replace(s, polindroms_notol, del, size_w, k);

    delete[] words;
    delete[] polindroms1;
    delete[] polindroms_k;
    delete[] polindroms_notol;
    delete[] polindroms;
    std::cout << s;

    return 0;
}
